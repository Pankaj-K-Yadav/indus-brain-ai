# ──────────────────────────────────────────────────────────────
# INDUS-BRAIN AI — Backend environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/indus-brain?retryWrites=true&w=majority

# ChromaDB (vector store)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=indus_brain_knowledge

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# File uploads (local storage for now)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25

# Knowledge pipeline tuning
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
EMBEDDING_BATCH_SIZE=50
RAG_TOP_K=6
RAG_MIN_SIMILARITY=0.4

# Logging
LOG_LEVEL=info
