# ──────────────────────────────────────────────────────────────
# INDUS-BRAIN AI — Frontend environment variables
# Copy to `.env`. Only variables prefixed with VITE_ are exposed to the client.
# ──────────────────────────────────────────────────────────────

# Base URL of the backend API
VITE_API_BASE_URL=http://localhost:4000/api

# Application display name
VITE_APP_NAME=INDUS-BRAIN AI
